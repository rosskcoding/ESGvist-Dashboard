#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_NAME="esgdashboard"
DEFAULT_DATABASE="esgvist"
DEFAULT_DSN="postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/${DEFAULT_DATABASE}"

PORTS=(3000 8000 5432 6379 9000 9001)

port_label() {
  case "$1" in
    3000) echo "Frontend app" ;;
    8000) echo "API" ;;
    5432) echo "PostgreSQL" ;;
    6379) echo "Redis" ;;
    9000) echo "MinIO API" ;;
    9001) echo "MinIO Console" ;;
    *) echo "Unknown" ;;
  esac
}

print_help() {
  cat <<EOF
ESGDashBoard default local runtime

Default stack: Docker Compose project '${PROJECT_NAME}'

Published ports:
  3000  Frontend app
  8000  API
  5432  PostgreSQL
  6379  Redis
  9000  MinIO API
  9001  MinIO Console

Default endpoints:
  App            http://localhost:3000
  Login          http://localhost:3000/login
  API health     http://127.0.0.1:8000/api/health
  Swagger        http://127.0.0.1:8000/docs
  MinIO Console  http://127.0.0.1:9001

Default database:
  Name  ${DEFAULT_DATABASE}
  DSN   ${DEFAULT_DSN}

Commands:
  ./start          Check ports, then start/rebuild the default Docker stack
  ./start up       Same as above
  ./start check    Validate that required ports are free or already owned by ${PROJECT_NAME}
  ./start status   Show ${PROJECT_NAME} container status
  ./start stop     Stop the ${PROJECT_NAME} stack
  ./start help     Show this help

If one of the default ports is occupied by another process or another Docker project,
this script exits with a warning instead of starting the wrong stack on the wrong ports.
EOF
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "error: docker is not installed or not on PATH" >&2
    exit 1
  fi
  if ! docker version >/dev/null 2>&1; then
    echo "error: Docker daemon is not reachable. Start Docker Desktop first." >&2
    exit 1
  fi
}

docker_owner_for_port() {
  local port="$1"
  python3 - "$port" <<'PY'
import re
import subprocess
import sys

port = int(sys.argv[1])
result = subprocess.run(
    ["docker", "ps", "--format", "{{.Names}}\t{{.Ports}}"],
    capture_output=True,
    text=True,
    check=False,
)
for line in result.stdout.splitlines():
    line = line.rstrip("\n")
    if not line:
        continue
    try:
        name, ports = line.split("\t", 1)
    except ValueError:
        continue
    for chunk in ports.split(","):
        chunk = chunk.strip()
        m = re.search(r":(\d+)(?:-(\d+))?->", chunk)
        if not m:
            continue
        start = int(m.group(1))
        end = int(m.group(2) or m.group(1))
        if start <= port <= end:
            print(name)
            raise SystemExit(0)
PY
}

local_owner_for_port() {
  local port="$1"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk 'NR==2 { printf "%s (pid %s)", $1, $2 }'
}

check_ports() {
  local conflicts=0

  echo "Checking default ${PROJECT_NAME} ports..."
  for port in "${PORTS[@]}"; do
    local label
    label="$(port_label "$port")"

    local docker_owner=""
    docker_owner="$(docker_owner_for_port "$port" || true)"
    if [[ -n "$docker_owner" ]]; then
      if [[ "$docker_owner" == "${PROJECT_NAME}-"* ]]; then
        echo "ok: ${label} port ${port} is already owned by ${docker_owner}"
      else
        echo "warning: ${label} port ${port} is occupied by Docker container ${docker_owner}, not ${PROJECT_NAME}" >&2
        conflicts=1
      fi
      continue
    fi

    local process_owner=""
    process_owner="$(local_owner_for_port "$port" || true)"
    if [[ -n "$process_owner" ]]; then
      echo "warning: ${label} port ${port} is occupied by local process ${process_owner}, not ${PROJECT_NAME}" >&2
      conflicts=1
      continue
    fi

    echo "ok: ${label} port ${port} is free"
  done

  if [[ "$conflicts" -ne 0 ]]; then
    cat >&2 <<EOF

Port conflict detected.
Free or stop the conflicting process/container first, then rerun:
  ./start

Expected default stack:
  frontend -> 3000
  api      -> 8000
  postgres -> 5432
  redis    -> 6379
  minio    -> 9000
  console  -> 9001
EOF
    exit 1
  fi
}

compose() {
  (
    cd "${ROOT_DIR}"
    docker compose -p "${PROJECT_NAME}" "$@"
  )
}

show_status() {
  compose ps
}

start_stack() {
  require_docker
  check_ports

  echo
  echo "Starting default Docker stack '${PROJECT_NAME}'..."
  (
    cd "${ROOT_DIR}"
    DB_AUTO_UPGRADE=true docker compose -p "${PROJECT_NAME}" up -d --build frontend api postgres redis minio
  )

  echo
  show_status
  echo
  cat <<EOF
Ready.

Open:
  App            http://localhost:3000
  API health     http://127.0.0.1:8000/api/health
  Swagger        http://127.0.0.1:8000/docs
  MinIO Console  http://127.0.0.1:9001
EOF
}

stop_stack() {
  require_docker
  compose down
}

command="${1:-up}"
case "${command}" in
  up|start)
    start_stack
    ;;
  check)
    require_docker
    check_ports
    ;;
  status)
    require_docker
    show_status
    ;;
  stop|down)
    stop_stack
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    echo "error: unknown command '${command}'" >&2
    echo >&2
    print_help
    exit 1
    ;;
esac
